rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ====== Custom Claims Functions ======
    function isAuth() {
      return request.auth != null;
    }
    function hasRole(role) {
      return isAuth() && request.auth.token.role == role;
    }
    function isAdmin() { return hasRole('Admin'); }
    function isManager() { return hasRole('Manager'); }
    function isAdminOrManager() { return isAdmin() || isManager(); }
    function isOperations() { return hasRole('Operations'); }
    function isAccountant() { return hasRole('Accountant'); }

    // ====== Users ======
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAdminOrManager() || request.auth.uid == resource.data.auth_uid;
      allow delete: if isAdmin();
    }

    // ====== Trips ======
    match /trips/{tripId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ====== Vehicles ======
    match /vehicles/{docId} {
      allow read: if isAuth();
      allow create: if isAdminOrManager() || isOperations();
      allow update: if isAdminOrManager() || isOperations();
      allow delete: if isAdmin();
    }

    // ====== Drivers ======
    match /drivers/{docId} {
      allow read: if isAuth();
      allow create: if isAdminOrManager() || isOperations();
      allow update: if isAdminOrManager() || isOperations();
      allow delete: if isAdmin();
    }

    // ====== Clients ======
    match /clients/{docId} {
      allow read: if isAuth();
      allow create: if isAdminOrManager() || isOperations();
      allow update: if isAdminOrManager() || isOperations();
      allow delete: if isAdmin();
    }

    // ====== Expenses ======
    match /expenses/{expenseId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ====== Fuel Balance ======
    match /fuelBalance/{docId} {
      allow read: if isAuth();
      allow create: if isAdminOrManager() || isOperations();
      allow update: if isAdminOrManager();
      allow delete: if isAdmin();
    }

    // ====== Fuel Transactions ======
    match /fuelTransactions/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdminOrManager();
      allow delete: if isAdmin();
    }

    // ====== Balance Transactions (عهدات) ======
    match /balanceTransactions/{docId} {
      allow read: if isAuth();
      allow create: if isAdminOrManager() || isAccountant();
      allow update: if isAdminOrManager();
      allow delete: if isAdmin();
    }

    // ====== Driver Advances ======
    match /driverAdvances/{docId} {
      allow read: if isAuth();
      allow create: if isAdminOrManager() || isOperations();
      allow update: if isAdminOrManager();
      allow delete: if isAdmin();
    }

    // ====== Maintenance ======
    match /maintenance/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ====== Notifications ======
    match /notifications/{notifId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ====== Settings (System) ======
    match /settings/{key} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ====== Audit Logs ======
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
