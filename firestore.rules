rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ====== Functions ======
    function isAuthenticated() {
      return request.auth != null;
    }
    function hasRole(role) {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdminOrManager() {
      return hasRole('Admin') || hasRole('Manager');
    }
    function isAdmin() {
      return hasRole('Admin');
    }

    // ====== Users ======
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isOwner(userId) || isAdminOrManager();
      allow delete: if isAdmin();
    }

    // ====== Trips ======
    match /trips/{tripId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ====== Vehicles ======
    match /vehicles/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrManager();
    }

    // ====== Drivers ======
    match /drivers/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrManager();
    }

    // ====== Clients ======
    match /clients/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrManager();
    }

    // ====== Expenses ======
    match /expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ====== Fuel Balance ======
    match /fuelBalance/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ====== Fuel Transactions ======
    match /fuelTransactions/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ====== Balance Transactions (عهدات) ======
    match /balanceTransactions/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrManager();
    }

    // ====== Driver Advances ======
    match /driverAdvances/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrManager();
    }

    // ====== Maintenance ======
    match /maintenance/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ====== Notifications ======
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ====== Settings (System) ======
    match /settings/{key} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ====== Audit Logs ======
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isAuthenticated();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
